# ============ LLM API Key ============
# 选一个你用的 LLM 提供商
# LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# 可选：OpenCode Go（DeepSeek V4 Flash）
# LLM_BASE_URL=https://opencode.ai/zen/go/v1
# LLM_MODEL=deepseek-v4-flash

# ============ Agent 配置 ============
# 要监控的群聊 QQ 号，逗号分隔
# WATCHED_GROUPS=123456789

# 要监控的好友 QQ 号，逗号分隔
# WATCHED_FRIENDS=987654321

# 你的 QQ 号（用于安全令牌识别主人）
# OWNER_QQ=987654321

# 上下文限制（超过 85% 时自动 reset 重建）
# MAX_CONTEXT_TOKENS=200000
